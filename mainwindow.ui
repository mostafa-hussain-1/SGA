  <property name="styleSheet">
   <string notr="true">/* 1. القاعدة العامة (الخلفية والأساسيات) */
QMainWindow {
    background-color: #121212;
}

/* ستايل الـ Frames الهادي (اللي مخدتش كلاس نيون) */
QFrame {
    background-color: #1E1E1E;
    border: 1px solid #2D2D2D;
    border-radius: 10px;
}

/* 2. ستايل النيون المخصص (استخدمه لأي Frame عايز تظهره، حط في الـ StyleSheet بتاعه: .neon_frame) */
QFrame[style_type=&quot;neon&quot;] {
    background-color: #252525;
    border: 2px solid #00FF66;
    border-radius: 10px;
}


/* 3. النصوص */
QLabel {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: bold;
    background: transparent;
    border: none;
}

QLabel[label_case=&quot;title&quot;]{
    color: #00FF66; /* أخضر نيون */
    font-size: 20px; /* خط كبير */
    font-weight: bold;
}

QLabel[label_case = &quot;head&quot;]{
    color: #FFFFFF;
    font-size: 30px;
    font-weight: bold;
    background: transparent;
    border: none;
}

QLabel[label_case = &quot;icon&quot;]{
    color: #FFFFFF;
    font-size: 30px;
    font-weight: bold;
    background: transparent;
    border: none;
}

QLabel[style_type = &quot;about&quot;] {
    color: #FFFFFF;
    font-size: 17px;
    font-weight: bold;
    background: transparent;
    border: none;
}

/* 4. الزراير */
QPushButton {
    background-color: #05C46B;
    color: #121212;
    border-radius: 12px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 18px;
}

QPushButton:hover {
    background-color: #33FF88;
}

QPushButton[style_type=&quot;delete&quot;]{
    background-color: #FF4757;
    color: white;
}

QPushButton[style_type=&quot;delete&quot;]:hover {
    background-color: #FF5555;
}

/* الحالة الافتراضية للزرار */
QPushButton#updateBtn {
    /* تدرج لوني من البرتقالي الغامق للبرتقالي الفاتح/الذهبي */
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0, 
                                stop: 0 #FF7A00, stop: 1 #FF9D00);
    color: #FFFFFF;
    font-weight: bold;
    font-size: 20px;
    border-radius: 8px; /* حواف ناعمة */
    border: 1px solid #FF9D00;
    padding: 6px 15px;
}

/* لما الماوس يروح عليه (إحساس الوهج أو الـ Glow) */
QPushButton#updateBtn:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0, 
                                stop: 0 #FF9D00, stop: 1 #FFB732);
    border: 1px solid #FFE066; /* تحديد أفتح عشان ينور */
}

/* لما اليوزر يدوس عليه */
QPushButton#updateBtn:pressed {
    background: #E66A00; /* لون برتقالي مطفي شوية يدي إحساس الضغطة */
    border: 1px solid #E66A00;
    padding-top: 8px; /* تريكة صايعة بتخلي النص ينزل ملي لتحت كأنه زرار حقيقي */
    padding-bottom: 4px;
}

QPushButton[style_type=&quot;emoji_btn&quot;] {
    background-color: transparent; /* شفاف تماماً عشان ياخد لون الفريم اللي تحته */
    border: none;                  /* مش عايزين إطار مضايق العين */
    font-size: 40px;               /* كبر حجم الإيموجي عشان يبقى واضح */
    border-radius: 8px;            /* تنعيم الحواف للحالة بتاعة الـ Hover */
    padding: 5px;
}

/* لما الماوس يروح على الزرار (Hover) */
QPushButton[style_type=&quot;emoji_btn&quot;]:hover {
    background-color: #252525;     /* إضاءة خفيفة جداً رمادي غامق خلف الإيموجي */
    border: 1px solid #00FF66;     /* خط نيون أخضر رفيع يحدد الزرار */
}

/* لما يدوس على الزرار (Pressed) */
QPushButton[style_type=&quot;emoji_btn&quot;]:pressed {
    background-color: #1A1A1A;     /* يغمق سيكة عشان يحس بالدوسة */
}


/* 5. خانات الإدخال */
QLineEdit {
    background-color: #2A2A2A;
    color: #FFFFFF;
    border: 1px solid #444444;
    border-radius: 5px;
    padding: 1px;
}

QLineEdit:focus {
    border: 1px solid #00FF66;
}

/* 6. الجدول (QTableWidget) */
QTableWidget {
    background-color: #1E1E1E; /* لون الخلفية الغامق بتاع الشاشة */
    alternate-background-color: #2A2A2A; /* لون الجراف اللي هيكسر الغمقان */
    color: #FFFFFF;
    gridline-color: #444444; /* خطوط الجدول */
    border: none;
}

/* لو عايز تلون الهيدر (العناوين اللي فوق) بنفس اللون عشان تقفل الشياكة */
QHeaderView::section {
    background-color: #2A2A2A; 
    color: #00FF66;
    border: 1px solid #444444;
    padding: 4px;
}
QTableWidget::item {
    border-bottom: 1px solid #2D2D2D;
    padding: 6px;
}

QTableWidget::item:selected {
    background-color: #00FF66;
    color: #121212;
}

QStackedWidget {
    background-color: rgba(30, 30, 30, 180); 
    border: 1px solid rgba(255, 255, 255, 40);
    border-radius: 15px;
}

QProgressBar {
    background-color: transparent;
    border: 1px solid #2D2D2D; /* إطار خفيف عشان يحدد مسار الشريط */
    border-radius: 5px;
    text-align: center; /* بيسنتر النسبة في النص */
	font-size: 30px;
    color: #FFFFFF;/* لون النسبة */
    font-weight: bold;
}
QProgressBar::chunk {
    background-color: #05C46B; /* لون الشريط الأخضر */
    border-radius: 5px;
}

/* 2. حالة الخطر (أقل من 60) */
QProgressBar[progress_state=&quot;bad&quot;]::chunk { background-color: #FF4757; }
QProgressBar[progress_state=&quot;bad&quot;] { color: #FFFFFF; }

/* 3. حالة المتوسط (من 60 لـ 85) */
QProgressBar[progress_state=&quot;mid&quot;]::chunk { background-color: #FFA502; }
QProgressBar[progress_state=&quot;mid&quot;] { color: #FFFFFF; }

/* 4. حالة الامتياز (فوق 85) */
QProgressBar[progress_state=&quot;good&quot;]::chunk { background-color: #00FF66; }
QProgressBar[progress_state=&quot;good&quot;] { color: #121212; }

/* 1. السطر ده هيلغي المربع الأزرق المنقط من على أي عنصر في البرنامج نهائياً */
* {
    outline: none;
}

/* 2. تظبيط شكل الـ ComboBox عشان مياخدش شكل الويندوز القديم */
QComboBox {
    border: 1px solid #333;
    border-radius: 4px;
    padding: 5px;
    background-color: #1e1e1e; /* درجة غامقة شيك */
    color: white;
}
QComboBox::drop-down {
    border: none;
}

/* 3. تظبيط شكل الـ CheckBox عشان يبقى موحد وثابت */
QCheckBox {
    color: white;
    spacing: 5px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #555;
    border-radius: 3px;
    background-color: #1e1e1e;
}
QCheckBox::indicator:checked {
    background-color: #2ea44f; /* لون أخضر لذيذ لما يتعلم عليه */
    border: 1px solid #2ea44f;
}
/* تظبيط القايمة المنسدلة من جوه عشان التحديد يبان بوضوح */
QComboBox QAbstractItemView {
    background-color: #1e1e1e; /* لون خلفية القايمة */
    color: white; /* لون الكلام العادي */
    
    /* ده السطر السحري اللي بيعمل اللون المبهج لما تقف بالماوس */
    selection-background-color: #0078D7; /* اللون الأزرق بتاع الويندوز الأصلي */
    selection-color: white; /* لون الكلام جوه التحديد */
    
    outline: none; /* عشان نلغي المربع المنقط القديم */
}

/* لو حابب تدي تأثير كمان للـ Item نفسه لما تمشي عليه بالماوس */
QComboBox QAbstractItemView::item:hover {
    background-color: #005a9e; /* درجة أزرق أغمق شوية للـ Hover */
    color: white;
}</string>
